     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Chi-square Test: Industry vs Meeting Booked\n",
      "Chi-square Statistic: 16.384, p-value: 0.0027\n",
      "Result: Significant association (p < 0.05)\n",
      "Conclusion: Industry DOES have a statistically significant effect on booking meetings\n"
     ]
    }
   ],
   "source": [
    "# Chi2 Contingency test to check industry vs meeting booked\n",
    "contingency_table = pd.crosstab(df['industry'], df['meeting_booked'])\n",
    "chi2_stat, p_value, dof, expected = chi2_contingency(contingency_table)\n",
    "print(\"Chi-square Test: Industry vs Meeting Booked\")\n",
    "print(f\"Chi-square Statistic: {chi2_stat:.3f}, p-value: {p_value:.4f}\")\n",
    "print(f\"Result: {'Significant association (p < 0.05)' if p_value < 0.05 else 'No significant association'}\")\n",
    "print(\"Conclusion: Industry DOES have a statistically significant effect on booking meetings\")"
   ]
  },
