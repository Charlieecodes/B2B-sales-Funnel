   ],
   "source": [
    "# Shapiro Wilks test to check if meeting_booked column follows a normal distribution\n",
    "shapiro_stat, p_value = shapiro(df['meeting_booked'])\n",
    "print(f'Shapiro Wilk Test result - Statistic= {shapiro_stat}, p-value= {p_value}')\n",
    "print(\"If p<0.05, data is not normally distributed\")\n",
    "print(f\"Conclusion: p-value is very low ({p_value:.2e}) so data is NOT NORMALLY DISTRIBUTED\")"
   ]
  },
