   "source": [
    "# Score all leads using Random Forest model\n",
    "df_original = df.copy()\n",
    "df_original['predicted_probability'] = rf_model.predict_proba(X)[:, 1]\n",
    "\n",
    "# Create lead score categories\n",
    "def assign_score(prob):\n",
    "    if prob >= 0.6:\n",
    "        return 'High'\n",
    "    elif prob >= 0.4:\n",
    "        return 'Medium'\n",
    "    else:\n",
    "        return 'Low'\n",
    "\n",
    "df_original['lead_score'] = df_original['predicted_probability'].apply(assign_score)\n",
    "df_original.head()"
   ]
